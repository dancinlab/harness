{
  "project": "harness",
  "profile": "default",
  "_note": "self-dogfooding — 엔진=repo 자신(submodule 없음). hardcore 가 아닌 default: protectedBranches·no-verify 차단 없이 자기 개발 흐름 보존. 번들 config/*.json 을 직접 규칙으로 사용.",
  "lockdown": {
    "files": ["cli/index.ts", "lib/paths.ts", "lib/config.ts", "lib/lockdown.ts", "modules/pre.ts"],
    "fromMarkdown": "README.md",
    "onEditReminder": "harness 코어 편집 — CHANGELOG.md 동시 갱신 + 임시 repo 스모크 테스트."
  },
  "enforcementFile": "config/enforcement.json",
  "keywordsFile": "config/keywords.json",
  "severityMapFile": "config/severity-map.json",
  "verify": {
    "checks": [{ "id": "typecheck", "cmd": "npx tsc --noEmit", "timeoutMs": 240000 }]
  },
  "lint": {
    "freshnessFiles": [],
    "changelog": {
      "file": "CHANGELOG.md",
      "triggerPattern": "\\.(ts)$",
      "ignore": ["(^|/)styles/", "(^|/)templates/", "(^|/)config/"]
    }
  },
  "guides": ["README.md", "CHANGELOG.md", "docs/architecture.md", "docs/install.md", "docs/extending.md", "docs/languages.md", "docs/hardcore.md"],
  "ledger": { "staleSec": 3600 }
}
